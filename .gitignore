debug_*.cr
fix_*.cr
test_*.cr
repro_*.cr
patch_*.cr

# Build artifacts and configuration
tree-sitter-config.json
mise.toml
walkers
extractor

# Tree-sitter build artifacts

# Compiled tree-sitter parser binary
parser

# Reference implementations for study only
vendor/ruby-tree-sitter/
vendor/tree-sitter-rust/

# Backup files
*.backup
*.bak

